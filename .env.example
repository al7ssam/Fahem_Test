PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/fahem
CLIENT_ORIGIN=http://localhost:5173
# Auth (production)
AUTH_JWT_SECRET=ضع_هنا_سلسلة_عشوائية_طويلة_جداً
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# استخدم newline حقيقي أو escaped newlines (\n) — الكود يحوّلها تلقائيًا
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# fallback محلي للتطوير فقط (غير موصى به في production cloud)
# FIREBASE_SERVICE_ACCOUNT_PATH=secrets/your-firebase-adminsdk.json
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=your-web-app-id
# اختياري: صفحة المتابعة بعد بريد «إعادة تعيين كلمة المرور» (يُضاف authAction=passwordReset)
VITE_FIREBASE_EMAIL_RESET_CONTINUE_URL=
# 1 يكشف «لا يوجد حساب» عند الطلب؛ الافتراضي إخفاء (رسالة عامة بعد الإرسال) لتقليل تعداد الحسابات
VITE_AUTH_PASSWORD_RESET_REVEAL_NOT_FOUND=
# إيميلات تمنح صلاحية admin تلقائياً بعد أول تسجيل دخول (مفصولة بفواصل)
AUTH_ADMIN_EMAILS=admin@example.com
# مدة JWT والجلسة (ثوانٍ) — اختياري؛ الافتراضيات: access 900، refresh 30 يوماً، كوكي الويب = refresh
# FAHEM_ACCESS_TTL_SECONDS=900
# FAHEM_REFRESH_TTL_SECONDS=2592000
# FAHEM_WEB_SESSION_TTL_SECONDS=2592000

# مرحلة البطاقات (نمط study_then_quiz) — بالمللي ثانية
STUDY_PHASE_MS=60000
STUDY_QUIZ_BLOCK_SIZE=8
MAX_STUDY_CARDS_DISPLAY=8
# حجم دفعة الأسئلة المُسبَقة لمراجعة واحدة في بداية المباراة (نمط study_then_quiz)
STUDY_MATCH_PREFETCH=50
# أقصى عدد لبطاقات تُجمع في المراجعة الشاملة الأولى
MAX_STUDY_CARDS_MATCH_START=1000

# مسار المحتوى البسيط — جدولة الخادم (اختياري)
# SIMPLE_CONTENT_SCHEDULER_BATCH_SIZE=10
# بعد الفشل: true (افتراضي) يُحدَّث موعد التشغيل التالي؛ false لا يُقدَّم الموعد فيُعاد الاستحقاق دون تأخير إضافي بنفس الفاصل
# SIMPLE_CONTENT_SCHEDULER_BUMP_AFTER_FAILURE=true

# مزودات الذكاء
# GEMINI_API_KEY=ضع_مفتاح_جيميني
# OPENAI_API_KEY=ضع_مفتاح_اوبن_اي_آي
