PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5432/fahem
CLIENT_ORIGIN=http://localhost:5173
# مفتاح سري لصفحة /admin و POST /api/admin/questions (رأس X-Admin-Secret)
ADMIN_SECRET=ضع_هنا_سلسلة_عشوائية_طويلة

# مرحلة البطاقات (نمط study_then_quiz) — بالمللي ثانية
STUDY_PHASE_MS=60000
STUDY_QUIZ_BLOCK_SIZE=8
MAX_STUDY_CARDS_DISPLAY=8
# حجم دفعة الأسئلة المُسبَقة لمراجعة واحدة في بداية المباراة (نمط study_then_quiz)
STUDY_MATCH_PREFETCH=50
# أقصى عدد لبطاقات تُجمع في المراجعة الشاملة الأولى
MAX_STUDY_CARDS_MATCH_START=1000
